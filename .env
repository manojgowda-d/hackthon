# ─────────────────────────────────────────────────────────
# Mini NotebookLM — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────
# Choose: "gemini" (default) or "openai"
LLM_PROVIDER=gemini

# ── API Keys ──────────────────────────────────────────────
# Get Gemini key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyA4dMkm1auYw1CMBvocewAlqiiLe9JNJGs

# Get OpenAI key: https://platform.openai.com/api-keys
# Only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=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

# ── Embedding Model ───────────────────────────────────────
# HuggingFace sentence-transformer (runs locally, no API key)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── RAG Settings ──────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_CHUNKS=5

# ── Session Memory ────────────────────────────────────────
MAX_HISTORY=10

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000

# ── YouTube Video Recommendations ────────────────────────────────────────────
# Get a FREE key at: https://console.developers.google.com/
# Steps: Create project → Enable "YouTube Data API v3" → Create API key
# Free quota: 10,000 units/day (1 search costs ~100 units)
YOUTUBE_API_KEY=AIzaSyD-JbzKrwhJvEvJqy2Fv3DNbUVsIjkObsw
